# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.tmp-pycache/
tmp_pycache/
.venv/

# Plugin dev artifacts
python/.venv/

# Codex CLI sandbox probe directory.
# Codex CLI 0.133.x writes ~200 four-byte "blat" probe files into a
# `.codex-tmp/` subdir of the spawning process's cwd during `codex exec`
# (used to verify the sandbox can write into the workspace). The files
# are not cleaned up automatically; pytest sessions trigger this by
# spawning codex as a child process. Our conftest.py session-finish hook
# removes the directory, but in case of an aborted run we don't want
# these probe files to land in git status.
.codex-tmp/
**/.codex-tmp/
.tmp/
**/.tmp/

# Local agent-loop runs (never commit user run logs)
.agent-loop/
.agent-loop-plan.md
.pytest-tmp*/

# OS
.DS_Store

#!/usr/bin/env sh
set -eu

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  plugin_root=$CLAUDE_PLUGIN_ROOT
else
  script_path=$0
  case "$script_path" in
    */*) ;;
    *) script_path=$(command -v -- "$script_path" 2>/dev/null || printf '%s\n' "$script_path") ;;
  esac
  plugin_root=$(CDPATH= cd -- "$(dirname -- "$script_path")/.." && pwd)
fi

run_if_python311() {
  py=$1
  shift
  if command -v "$py" >/dev/null 2>&1 && "$py" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' >/dev/null 2>&1; then
    exec "$py" "$plugin_root/python/agent_loop/__main__.py" "$@"
  fi
}

run_if_python311 "$plugin_root/.venv/bin/python" "$@"
run_if_python311 "$plugin_root/python/.venv/bin/python" "$@"
run_if_python311 python "$@"
run_if_python311 python3 "$@"

printf '%s\n' "agent-loop: Python 3.11+ is required on PATH" >&2
exit 127
